{
  "name": "ephemeral-environment-action",
  "version": "1.0.0",
  "private": true,
  "description": "Github Action that sets up an ephemeral environment",
  "main": "lib/index.js",
  "scripts": {
    "build": "tsc && ncc build lib/index.js -o dist",
    "lint": "eslint src/**/*.ts",
    "all": "npm run build && npm run lint"
  },
  "dependencies": {
    "@actions/core": "^2.0.0",
    "@actions/exec": "^2.0.0",
    "@actions/tool-cache": "^3.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "@types/semver": "^7.7.1",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vercel/ncc": "^0.38.4",
    "eslint": "^10.0.2",
    "eslint-config-google": "^0.14.0",
    "globals": "^17.4.0",
    "typescript": "^5.9.3"
  }
}
